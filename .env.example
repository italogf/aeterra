# Aeterra: World Breaker — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3011
NODE_ENV=development

# Security — generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_strong_random_secret

# Development helpers (remove or set to 0 in production)
ALLOW_DEV_RESPAWN=1
MIN_GROWTH_MS=1000

# NPC AI — optional (game runs fine without these)
# Option A: OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Option B: OpenRouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
# OPENROUTER_SITE_URL=http://localhost:3011
# OPENROUTER_SITE_NAME=Aeterra
